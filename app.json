{
  "expo": {
    "name": "LexiTrie",
    "slug": "lexitrie",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lexitrie",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lexitrie.app",
      "icon": "assets/Logo.png"
    },
    "android": {
      "package": "com.lexitrie.app",
      "icon": "assets/Logo.png"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
